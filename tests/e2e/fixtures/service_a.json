{
  "openapi": "3.0.0",
  "info": { "title": "Users API", "version": "1.0" },
  "paths": {
    "/users": {
      "get": {
        "operationId": "listUsers",
        "responses": {
          "200": {
            "description": "List of users",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/User" }
              }
            }
          }
        }
      }
    },
    "/users/{id}": {
      "get": {
        "operationId": "getUser",
        "responses": { "200": { "description": "A user" } }
      }
    },
    "/users/{id}/items": {
      "get": {
        "operationId": "getUserItems",
        "responses": {
          "200": {
            "description": "Items of user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Item" }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "operationId": "healthA",
        "responses": { "200": { "description": "ok" } }
      }
    },
    "/internal/stats": {
      "get": {
        "operationId": "internalStats",
        "responses": { "200": { "description": "ok" } }
      }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "Item": {
        "type": "object",
        "properties": {
          "label": { "type": "string" },
          "qty": { "type": "integer" }
        }
      }
    }
  }
}
